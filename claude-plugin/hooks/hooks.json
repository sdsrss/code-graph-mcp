{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "tool == \"Write\" || tool == \"Edit\"",
        "hooks": [
          {
            "type": "command",
            "command": "code-graph-mcp incremental-index --quiet",
            "timeout": 10
          }
        ],
        "description": "Auto-update code graph index after file edits"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node claude-plugin/scripts/session-init.js",
            "timeout": 8
          }
        ],
        "description": "Health check, StatusLine registration, and update check at session start"
      }
    ]
  }
}
